[user]
	email = psauxwwf@d6f.ru
	name = psauxwwf
	signingkey = psauxwwf
[credential]
	helper = store
[core]
	autocrlf = false
	editor = hx
	sshCommand = ssh -i ~/.ssh/id_ed25519_git_psauxwwf -o IdentitiesOnly=yes
[http]
	sslVerify = false
[commit]
	gpgsign = true
[init]
	defaultBranch = master
[diff]
	algorithm = histogram
[color]
	ui = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[includeIf "gitdir:~/files/second-brain.md/"]
    path = ~/files/second-brain.md/.gitconfig

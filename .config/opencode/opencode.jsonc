{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": [
    "AGENTS.md",
  ],
  "permission": {
    "lsp": "allow"
  },
  "provider": {
    "FreeGLM": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:5000/v1",
        // "apiKey": "{env:ZAI_API_KEY}",
      },
      "models": {
        "glm-4.7-flash": {
          "attachment": true,
          "tool_call": true,
          "reasoning": true,
        }
      }
    },
    "LMStudio": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3-4b-instruct-2507": {
          "attachment": true,
          "tool_call": true,
          "reasoning": true,
        },
        "qwen3-vl-2b-instruct": {
          "attachment": true,
          "tool_call": true,
          "reasoning": true,
        },
      }
    },
    "Ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3:1.7b": {
          "attachment": true,
          // 1.7b может галюцинировать с tools
          "tool_call": false,
          "reasoning": false,
          "limit": {
            "context": 40000,
            "output": 4096
          },
          "options": {
            // отключает thinking
            "reasoningEffort": "none", // вместо high/medium/low
            "reasoningSummary": "none",
            "textVerbosity": "low",
            // - 0.0 — максимально детерминированно, сухо, без креатива.
            // - 0.1 – 0.2 — чуть гибкости, но всё ещё “по фактам”.
            // - 0.3 – 0.6 — сбалансированный режим.
            // - > 0.7 — креатив, болтовня, вариативность.
            "temperature": 0.0,
          }
        },
        "glm-4.7:cloud": {
          "attachment": true,
          "tool_call": true,
          "reasoning": true,
        },
        "qwen3-coder:480b-cloud": {
          "attachment": true,
          "tool_call": true,
          "reasoning": true,
        }
      }
    }
  },
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--secrets",
        "$HOME/.env.docker",
      ],
    },
    // https://opencode.ai/docs/mcp-servers/
    "MCP_CONTEXT7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    },
    "MCP_GH_GREP": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.grep.app"
    },
    // "MCP_EXA": {
    //   "type": "remote",
    //   "enabled": false,
    //   "url": "https://mcp.exa.ai/mcp"
    // },
    // "MCP_CHROME": {
    //   "type": "local",
    //   "enabled": false,
    //   "command": [
    //     "chrome-devtools-mcp",
    //     "-e",
    //     "/opt/chromium/chrome",
    //     "--proxyServer",
    //     "socks5://127.0.0.1:1080",
    //     "--autoConnect"
    //   ],
    // },
    // "MCP_PERPLEXITY": {
    //   "type": "local",
    //   "enabled": false,
    //   "command": [
    //     "perplexity-mcp",
    //   ],
    //   "environment": {},
    // },
  },
}
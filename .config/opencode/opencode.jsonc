{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    // "opencode-openloop@latest",
    "opencode-gemini-auth@latest",
  ],
  "autoupdate": false,
  "instructions": [
    "AGENTS.md",
  ],
  "permission": {
    "lsp": "allow"
  },
  "disabled_providers": [
    "ollama-cloud",
    "opencode",
    "perplexity",
    "perplexity-agent",
    "google-vertex",
    "google-vertex-anthropic",
  ],
  "provider": {
    "openai": {
      "whitelist": [
        "gpt-5.3-codex",
        "gpt-5.4",
        "gpt-5.4-fast",
        "gpt-5.5",
        "gpt-5.5-fast",
      ]
    },
    "google": {
      "options": {
        "projectId": "opencode-493919",
      },
      "whitelist": [
        "gemini-3.1-flash-lite-preview",
        "gemini-3.1-pro-preview",
        "gemini-3-flash-preview",
        "gemini-3-pro-preview",
      ]
    },
    "freeglm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "FreeGLM (local)",
      "options": {
        "baseURL": "http://127.0.0.1:5000/v1",
        // "apiKey": "{env:ZAI_API_KEY}",
      },
      "models": {
        "glm-4.7-flash": {
          "attachment": true,
          "tool_call": true,
          "reasoning": true,
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "blacklist": [
        "openai/gpt-oss-20b",
        "qwen/qwen3-30b-a3b-2507",
        "qwen/qwen3-coder-30b",
      ],
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3:1.7b": {
          "attachment": true,
          "tool_call": false,
          "reasoning": false,
          "limit": {
            "context": 40000,
            "output": 4096
          },
          "options": {
            // отключает thinking
            "reasoningEffort": "none", // вместо high/medium/low
            "reasoningSummary": "none",
            "textVerbosity": "low",
            "temperature": 0.0,
          }
        }
      }
    }
  },
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--secrets",
        "$HOME/.env.docker",
      ],
    },
    "MCP_CONTEXT7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    },
    "MCP_GH_GREP": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.grep.app"
    },
    // "MCP_EXA": {
    //   "type": "remote",
    //   "enabled": false,
    //   "url": "https://mcp.exa.ai/mcp"
    // },
    // "MCP_CHROME": {
    //   "type": "local",
    //   "enabled": false,
    //   "command": [
    //     "chrome-devtools-mcp",
    //     "-e",
    //     "/opt/chromium/chrome",
    //     "--proxyServer",
    //     "socks5://127.0.0.1:1080",
    //     "--autoConnect"
    //   ],
    // },
    // "MCP_PERPLEXITY": {
    //   "type": "local",
    //   "enabled": false,
    //   "command": [
    //     "perplexity-mcp",
    //   ],
    //   "environment": {},
    // },
  },
}
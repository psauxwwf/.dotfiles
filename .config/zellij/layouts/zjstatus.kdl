// https://github.com/dj95/zjstatus/discussions/44?sort=top
// https://gist.github.com/xtrasmal/1a56f8bb269ff769492cc5287022ce0f

layout {
    default_tab_template {
        children
        pane size=1 borderless=false {
            plugin location="zjstatus" {
                format_left   "#[fg=#6867AF,bold]  {mode}"
                format_center "#[fg=black]{tabs}"
                format_right  "#[fg=#94E2D5]{swap_layout}#[fg=#6867AF,bold] {datetime}#[fg=cyan]"
                format_space  "#[fg=yellow] "
                // {session}
                hide_frame_for_single_pane "false"
                border_enabled  "false"

                mode_normal        " {name} #[fg=#6C7086] "
                mode_locked        " {name} #[fg=#6C7086] "
                mode_resize        " {name} #[fg=#6C7086] "
                mode_pane          " {name} #[fg=#6C7086] "
                mode_tab           " {name} #[fg=#6C7086] "
                mode_scroll        " {name} #[fg=#6C7086] "
                mode_enter_search  " {name} #[fg=#6C7086] "
                mode_search        " {name} #[fg=#6C7086] "
                mode_rename_tab    " {name} #[fg=#6C7086] "
                mode_rename_pane   " {name} #[fg=#6C7086] "
                mode_session       " {name} #[fg=#6C7086] "
                mode_move          " {name} #[fg=#6C7086] "
                mode_prompt        " {name} #[fg=#6C7086] "
                mode_tmux          " {name} #[fg=#6C7086] "

                // formatting for inactive tabs
                tab_normal              "#[fg=#6C7086]{index} {name}"
                tab_normal_fullscreen   "#[fg=#6C7086]{index} {name}"
                tab_normal_sync         "#[fg=#6C7086]{index} {name}"

                // formatting for the current active tab
                tab_active              "#[fg=blue,bold]{index} {name}#[fg=yellow]{floating_indicator}"
                tab_active_fullscreen   "#[fg=yellow,bold]{index} {name}#[fg=yellow]{fullscreen_indicator}"
                tab_active_sync         "#[fg=green,bold]{index} {name}#[fg=yellow]{sync_indicator}"

                // separator between the tabs
                tab_separator           "#[fg=cyan,bold]  "

                // indicators
                tab_sync_indicator       " 󰓦 "
                tab_fullscreen_indicator " 󰊓 "
                tab_floating_indicator   " 󰹙 "

                swap_layout_format        "#[fg=#94E2D5,bold]{name} "
                swap_layout_hide_if_empty "true"

                datetime        "#[fg=#6C7086,bold] {format} "
                datetime_format "%A, %d %b %Y %H:%M:%S"
                datetime_timezone "Europe/Moscow"
            }
        }
    }
    // left main pane (60%) + right stacked panes
    swap_tiled_layout name="Lstack" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane stacked=true {
                    children
                }
            }
        }
    }
    // splits: asymmetric split-tree like kitty's splits example
    swap_tiled_layout name="Split" {
        tab max_panes=2 {
            pane
        }
        tab exact_panes=3 {
            pane split_direction="vertical" {
                pane size="60%"
                pane
            }
        }
        tab exact_panes=4 {
            pane split_direction="vertical" {
                pane size="60%"
                pane split_direction="horizontal" {
                    pane
                    pane
                }
            }
        }
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane split_direction="horizontal" {
                    pane
                    pane split_direction="horizontal" {
                        children
                    }
                }
            }
        }
    }
    // horizontal in kitty: all panes side by side
    swap_tiled_layout name="Vert" {
        tab exact_panes=3 {
            pane split_direction="vertical" {
                pane size="60%"
                pane
            }
        }
        tab {
            pane split_direction="vertical" {
                children
            }
        }
    }
    // vertical in kitty: all panes one below another
    swap_tiled_layout name="Horiz" {
        tab exact_panes=3 {
            pane split_direction="horizontal" {
                pane size="70%"
                pane
            }
        }
        tab {
            pane split_direction="horizontal" {
                children
            }
        }
    }
    
    // stack: one visible pane, others collapsed as a stack
    swap_tiled_layout name="Stack" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane stacked=true {
                children
            }
        }
    }
    // tall: one big full-height pane + right-side vertical tiling
    swap_tiled_layout name="Tall" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane split_direction="horizontal" {
                    children
                }
            }
        }
    }
    // fat: one big full-width pane + bottom horizontal tiling
    swap_tiled_layout name="Fat" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane split_direction="horizontal" {
                pane size="60%"
                pane split_direction="vertical" {
                    children
                }
            }
        }
    }
    // grid: balanced 1..6 pane presets
    swap_tiled_layout name="Grid" {
        tab exact_panes=2 {
            pane
        }
        tab exact_panes=3 {
            pane split_direction="vertical" {
                pane
                pane
            }
        }
        tab exact_panes=4 {
            pane split_direction="vertical" {
                pane
                pane
                pane
            }
        }
        tab exact_panes=5 {
            pane split_direction="horizontal" {
                pane split_direction="vertical" {
                    pane
                    pane
                }
                pane split_direction="vertical" {
                    pane
                    pane
                }
            }
        }
        tab exact_panes=6 {
            pane split_direction="horizontal" {
                pane split_direction="vertical" {
                    pane
                    pane
                    pane
                }
                pane split_direction="vertical" {
                    pane
                    pane
                }
            }
        }
        tab {
            pane split_direction="horizontal" {
                pane split_direction="vertical" {
                    pane
                    pane
                    pane
                }
                pane split_direction="vertical" {
                    pane
                    pane
                    children
                }
            }
        }
    }
}

// https://github.com/dj95/zjstatus/discussions/44?sort=top
// https://gist.github.com/xtrasmal/1a56f8bb269ff769492cc5287022ce0f

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                format_left   "#[fg=#BD93F9]  {session} {mode} #[fg=#6272A4]{tabs}"
                format_center ""
                format_right  "{swap_layout}#[fg=#BD93F9] {datetime}"
                format_space  "#[fg=#6272A4] "
                // {session}
                hide_frame_for_single_pane "false"
                border_enabled  "false"

                mode_normal        "#[bg=#282A36,fg=#50FA7B]#[bg=#50FA7B,fg=#282A36]NORMAL#[bg=#282A36,fg=#50FA7B]"
                mode_locked        "#[bg=#282A36,fg=#282A36]#[bg=#282A36,fg=#8BE9FD]LOCKED#[bg=#282A36,fg=#282A36]"
                mode_resize        "#[bg=#282A36,fg=#FF79C6]#[bg=#FF79C6,fg=#282A36]RESIZE#[bg=#282A36,fg=#FF79C6]"
                mode_pane          "#[bg=#282A36,fg=#82AAFF]#[bg=#82AAFF,fg=#282A36]PANE#[bg=#282A36,fg=#82AAFF]"
                mode_tab           "#[bg=#282A36,fg=#BD93F9]#[bg=#BD93F9,fg=#282A36]TAB#[bg=#282A36,fg=#BD93F9]"
                mode_scroll        "#[bg=#282A36,fg=#FFB86C]#[bg=#FFB86C,fg=#282A36]SCROLL#[bg=#282A36,fg=#FFB86C]"
                mode_enter_search  "#[bg=#282A36,fg=#82AAFF]#[bg=#82AAFF,fg=#282A36]SEARCH#[bg=#282A36,fg=#82AAFF]"
                mode_search        "#[bg=#282A36,fg=#8BE9FD]#[bg=#8BE9FD,fg=#282A36]SEARCH#[bg=#282A36,fg=#8BE9FD]"
                mode_rename_tab    "#[bg=#282A36,fg=#FF79C6]#[bg=#FF79C6,fg=#282A36]RETAB#[bg=#282A36,fg=#FF79C6]"
                mode_rename_pane   "#[bg=#282A36,fg=#BD93F9]#[bg=#BD93F9,fg=#282A36]REPANE#[bg=#282A36,fg=#BD93F9]"
                mode_session       "#[bg=#282A36,fg=#BD93F9]#[bg=#BD93F9,fg=#282A36]SESSION#[bg=#282A36,fg=#BD93F9]"
                mode_move          "#[bg=#282A36,fg=#FFB86C]#[bg=#FFB86C,fg=#282A36]MOVE#[bg=#282A36,fg=#FFB86C]"
                mode_prompt        "#[bg=#282A36,fg=#8BE9FD]#[bg=#8BE9FD,fg=#282A36]PROMPT#[bg=#282A36,fg=#8BE9FD]"
                mode_tmux          "#[bg=#282A36,fg=#8BE9FD]#[bg=#8BE9FD,fg=#282A36]TMUX#[bg=#282A36,fg=#8BE9FD]"

                // formatting for inactive tabs
                tab_normal              "#[bg=#282A36,fg=#82AAFF]#[bg=#82AAFF,fg=#282A36]{index} #[bg=#282A36,fg=#6272A4] {name}{floating_indicator}#[bg=#282A36,fg=#282A36]"
                tab_normal_fullscreen   "#[bg=#282A36,fg=#82AAFF]#[bg=#82AAFF,fg=#282A36]{index} #[bg=#282A36,fg=#6272A4] {name}{fullscreen_indicator}#[bg=#282A36,fg=#282A36]"
                tab_normal_sync         "#[bg=#282A36,fg=#82AAFF]#[bg=#82AAFF,fg=#282A36]{index} #[bg=#282A36,fg=#6272A4] {name}{sync_indicator}#[bg=#282A36,fg=#282A36]"

                // formatting for the current active tab
                tab_active              "#[bg=#282A36,fg=#BD93F9]#[bg=#BD93F9,fg=#282A36]{index} #[bg=#282A36,fg=#BD93F9] {name}{floating_indicator}#[bg=#282A36,fg=#282A36]"
                tab_active_fullscreen   "#[bg=#282A36,fg=#BD93F9]#[bg=#BD93F9,fg=#282A36]{index} #[bg=#282A36,fg=#BD93F9] {name}{fullscreen_indicator}#[bg=#282A36,fg=#282A36]"
                tab_active_sync         "#[bg=#282A36,fg=#BD93F9]#[bg=#BD93F9,fg=#282A36]{index} #[bg=#282A36,fg=#BD93F9] {name}{sync_indicator}#[bg=#282A36,fg=#282A36]"

                // separator between the tabs
                tab_separator           "#[bg=#282A36] "

                // indicators
                tab_sync_indicator       " [S]"
                tab_fullscreen_indicator " [F]"
                tab_floating_indicator   " [FL]"

                swap_layout_format        "#[bg=#282A36,fg=#82AAFF]#[bg=#82AAFF,fg=#282A36]{name}#[bg=#282A36,fg=#82AAFF] "
                swap_layout_hide_if_empty "true"

                datetime        "{format} "
                datetime_format "%a, %d %b %H:%M:%S"
                datetime_timezone "Europe/Moscow"
            }
        }
    }
    // left main pane (55%) + right stacked panes
    swap_tiled_layout name="LSTACK" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane split_direction="vertical" {
                pane size="55%"
                pane stacked=true {
                    children
                }
            }
        }
    }
    // splits: asymmetric split-tree like kitty's splits example
    swap_tiled_layout name="SPLIT" {
        tab max_panes=2 {
            pane
        }
        tab exact_panes=3 {
            pane split_direction="vertical" {
                pane size="55%"
                pane
            }
        }
        tab exact_panes=4 {
            pane split_direction="vertical" {
                pane size="55%"
                pane split_direction="horizontal" {
                    pane
                    pane
                }
            }
        }
        tab {
            pane split_direction="vertical" {
                pane size="55%"
                pane split_direction="horizontal" {
                    pane
                    pane split_direction="horizontal" {
                        children
                    }
                }
            }
        }
    }
    // horizontal in kitty: all panes side by side
    swap_tiled_layout name="VERT" {
        tab exact_panes=3 {
            pane split_direction="vertical" {
                pane size="55%"
                pane
            }
        }
        tab {
            pane split_direction="vertical" {
                children
            }
        }
    }
    // vertical in kitty: all panes one below another
    swap_tiled_layout name="HORIZ" {
        tab exact_panes=3 {
            pane split_direction="horizontal" {
                pane size="60%"
                pane
            }
        }
        tab {
            pane split_direction="horizontal" {
                children
            }
        }
    }
    
    // stack: one visible pane, others collapsed as a stack
    swap_tiled_layout name="STACK" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane stacked=true {
                children
            }
        }
    }
    // tall: one big full-height pane + right-side vertical tiling
    swap_tiled_layout name="TALL" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane split_direction="vertical" {
                pane size="55%"
                pane split_direction="horizontal" {
                    children
                }
            }
        }
    }
    // fat: one big full-width pane + bottom horizontal tiling
    swap_tiled_layout name="FAT" {
        tab max_panes=2 {
            pane
        }
        tab {
            pane split_direction="horizontal" {
                pane size="55%"
                pane split_direction="vertical" {
                    children
                }
            }
        }
    }
    // grid: balanced 1..6 pane presets
    swap_tiled_layout name="GRID" {
        tab exact_panes=2 {
            pane
        }
        tab exact_panes=3 {
            pane split_direction="vertical" {
                pane
                pane
            }
        }
        tab exact_panes=4 {
            pane split_direction="vertical" {
                pane
                pane
                pane
            }
        }
        tab exact_panes=5 {
            pane split_direction="horizontal" {
                pane split_direction="vertical" {
                    pane
                    pane
                }
                pane split_direction="vertical" {
                    pane
                    pane
                }
            }
        }
        tab exact_panes=6 {
            pane split_direction="horizontal" {
                pane split_direction="vertical" {
                    pane
                    pane
                    pane
                }
                pane split_direction="vertical" {
                    pane
                    pane
                }
            }
        }
        tab {
            pane split_direction="horizontal" {
                pane split_direction="vertical" {
                    pane
                    pane
                    pane
                }
                pane split_direction="vertical" {
                    pane
                    pane
                    children
                }
            }
        }
    }
}

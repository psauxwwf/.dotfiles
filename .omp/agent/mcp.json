{
  "$schema": "https://raw.githubusercontent.com/can1357/oh-my-pi/main/packages/coding-agent/src/config/mcp-schema.json",
  "mcpServers": {
    "MCP_DOCKER": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run",
        "--secrets",
        "$HOME/.env.docker"
      ]
    },
    "MCP_CONTEXT7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "MCP_GH_GREP": {
      "type": "http",
      "url": "https://mcp.grep.app"
    }
  }
}